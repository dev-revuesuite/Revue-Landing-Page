# Razorpay API Credentials
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx

# Frontend URL(s) for CORS (comma-separated for multiple)
FRONTEND_URL=https://revuesuite.com
# Local example: FRONTEND_URL=http://127.0.0.1:5501
# In development, localhost / 127.0.0.1 on any port is also allowed automatically

# GSTVerify API (https://gstverify.co.in/dev-api/)
GSTVERIFY_API_KEY=your_gstverify_api_key

# Google Sheets via Apps Script web app URL (/exec)
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your_deployment_id/exec

# Server Configuration
PORT=3000
NODE_ENV=development

# ============================================================
# REVUE CMS — Environment variables
# Copy this file to .env.local for local dev, and set these in
# Vercel's Project Settings → Environment Variables for prod.
# ============================================================

# --- Supabase ---
# From your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# PUBLIC key for browser + login (pick ONE of these from the API page):
#   • Legacy: "anon" "public"  → starts with eyJhbGci...
#   • New:    "publishable"   → starts with sb_publishable_
# Do NOT use sb_secret_ here — that breaks login.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Server-only: "service_role" "secret" → starts with eyJhbGci...
# NEVER prefix with NEXT_PUBLIC_ or commit to git.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# --- Site ---
# Used for absolute URLs in OG tags, sitemap, RSS, JSON-LD.
# In production this is https://revuesuite.com (or wherever the
# blog is served from). Local dev defaults to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required: only this email can sign in to /cms (your Supabase Auth admin user)
ALLOWED_CMS_EMAIL=your-admin@example.com

# Optional: revalidation secret for on-demand revalidation webhooks
REVALIDATE_SECRET=change-me-to-a-long-random-string

# ============================================================
# BLOG AUTOMATION (AI content pipeline)
# ============================================================

# --- Trigger security ---
# Long random string. The cron endpoint (/api/cron/generate-posts) rejects any
# request whose "Authorization: Bearer <CRON_SECRET>" header doesn't match.
CRON_SECRET=change-me-to-a-long-random-string

# --- Google Sheet (Apps Script Web App) ---
# Deploy docs/google-apps-script.gs as a Web App and paste its /exec URL here.
GOOGLE_SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/XXXX/exec
# Must match the SECRET constant inside the Apps Script.
GOOGLE_SHEETS_SECRET=change-me-to-a-long-random-string

# --- Gemini ---
# GEMINI_API_KEY=...
# GEMINI_TEXT_MODEL=gemini-2.5-flash-lite

# --- System author (optional; otherwise resolved by slug "revue-editorial") ---
# SYSTEM_AUTHOR_ID=

# --- Volume / pacing (start small; raise to scale) ---
DAILY_TARGET=10    # articles/day drip target (~1 every 2.4 hours)
DAILY_CAP=12       # hard safety cap per day
BATCH_SIZE=1       # one pipeline step per cron tick
STALE_PROCESSING_MINUTES=5  # reclaim jobs stuck mid-step (see /api/cron/reclaim-jobs)
GOOGLE_SHEETS_TIMEOUT_MS=30000  # Apps Script read/write timeout (default 30s)
